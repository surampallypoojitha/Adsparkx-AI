# Copy this file to .env and fill in your real values.
# Never commit .env because it contains secrets.

# Gemini Developer API key from Google AI Studio.
GOOGLE_API_KEY=your_google_api_key_here

# Default Gemini model used by the support agent.
GEMINI_MODEL=gemini-2.5-flash

# Gemini embedding model used for vector search.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Local ChromaDB persistence directory.
CHROMA_PERSIST_DIR=data/chroma

# Chroma collection name for this assignment.
CHROMA_COLLECTION_NAME=persona_support_kb

# Retrieval settings. We will tune these in later phases.
RETRIEVAL_TOP_K=4
RETRIEVAL_CONFIDENCE_THRESHOLD=0.55

# Document chunking settings.
CHUNK_SIZE=800
CHUNK_OVERLAP=120
